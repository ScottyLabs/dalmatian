{
    "nodeModulesDir": "auto",
    "lock": true,
    "exclude": [".devenv", ".direnv", "build", "drizzle", "src/data"],
    "tasks": {
        "start": "deno run --allow-all src/index.ts",
        "build": "deno compile --frozen --no-check --allow-all --cached-only --include drizzle --include src --output dist/bin/dalmatian src/index.ts",
        "db:generate": "deno run --allow-all npm:drizzle-kit generate",
        "db:migrate": "deno run --allow-all src/db/migrate.ts",
        "db:push": "deno run --allow-all npm:drizzle-kit push",
        "db:studio": "deno run --allow-all npm:drizzle-kit studio",
        "test": "deno test --allow-all tests/",
        "lint": "oxlint",
        "format": "treefmt --no-cache"
    },
    "imports": {
        "@logtape/logtape": "npm:@logtape/logtape@^2.1.1",
        "@std/expect": "jsr:@std/expect@^1",
        "@std/testing/bdd": "jsr:@std/testing@^1/bdd",
        "csv-parse": "npm:csv-parse@^6.1.0",
        "discord.js": "npm:discord.js@14.24.0",
        "drizzle-kit": "npm:drizzle-kit@1.0.0-rc.3",
        "drizzle-orm": "npm:drizzle-orm@1.0.0-rc.3",
        "drizzle-orm/pg-core": "npm:drizzle-orm@1.0.0-rc.3/pg-core",
        "drizzle-orm/postgres-js": "npm:drizzle-orm@1.0.0-rc.3/postgres-js",
        "drizzle-orm/postgres-js/migrator": "npm:drizzle-orm@1.0.0-rc.3/postgres-js/migrator",
        "fast-fuzzy": "npm:fast-fuzzy@^1.12.0",
        "ms": "npm:ms@^2.1.3",
        "postgres": "npm:postgres@^3.4.5",
        "zod": "npm:zod@^3.25.76"
    },
    "compilerOptions": {
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "noPropertyAccessFromIndexSignature": true
    }
}
